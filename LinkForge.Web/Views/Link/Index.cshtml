@model List<LinkForge.Application.DTO.ShortLinkDto>

<div class="card shadow-sm">

    <div class="card-body">

        <div class="d-flex justify-content-between mb-3">

            <h4>Your links</h4>

            <a class="btn btn-primary"
               asp-action="Create">
                + New Link
            </a>

        </div>

        <table class="table table-hover">

            <thead class="table-light">

            <tr>
                <th>Original URL</th>
                <th>Short Link</th>
                <th>Clicks</th>
                <th>Created</th>
                <th></th>
            </tr>

            </thead>

            <tbody>

            @foreach (var link in Model)
            {
                <tr>

                    <td>
                        <a href="@link.OriginalUrl"
                           target="_blank">
                            @link.OriginalUrl
                        </a>
                    </td>

                    <td>
                        <a href="/@link.ShortCode"
                           target="_blank"
                           class="fw-bold">
                            @link.ShortCode
                        </a>
                    </td>

                    <td>
                        <span class="badge bg-secondary">
                            @link.ClickCount
                        </span>
                    </td>

                    <td>
                        @link.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </td>

                    <td>

                        <a class="btn btn-sm btn-outline-primary"
                           asp-action="Edit"
                           asp-route-id="@link.Id">
                            Edit
                        </a>

                        <a class="btn btn-sm btn-outline-danger"
                           asp-action="Delete"
                           asp-route-id="@link.Id">
                            Delete
                        </a>

                    </td>

                </tr>
            }

            </tbody>

        </table>

    </div>

</div>