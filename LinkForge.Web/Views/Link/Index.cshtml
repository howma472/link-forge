@model List<LinkForge.Domain.Entities.ShortLink>

<h2 class="mb-4">URL Shortener</h2>

<form asp-controller="Link" asp-action="Create" method="post" class="row g-2 mb-4">

    <div class="col-md-10">
        <input name="Url"
               class="form-control"
               placeholder="Enter URL..."
               required />
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">
            Create
        </button>
    </div>

</form>

<table class="table table-striped table-bordered">

    <thead class="table-dark">
    <tr>
        <th>Long URL</th>
        <th>Short URL</th>
        <th>Created</th>
        <th>Clicks</th>
        <th>Actions</th>
    </tr>
    </thead>

    <tbody>

    @foreach (var link in Model)
    {
        <tr>

            <td>@link.OriginalUrl</td>

            <td>
                <a href="/@link.ShortCode" target="_blank">
                    @Context.Request.Scheme://@Context.Request.Host/@link.ShortCode
                </a>
            </td>

            <td>@link.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

            <td>@link.ClickCount</td>

            <td>

                <a class="btn btn-sm btn-warning"
                   asp-controller="Link"
                   asp-action="Edit"
                   asp-route-id="@link.Id">
                    Edit
                </a>

                <a class="btn btn-sm btn-danger"
                   asp-controller="Link"
                   asp-action="Delete"
                   asp-route-id="@link.Id"
                   onclick="return confirm('Delete this link?');">
                    Delete
                </a>

            </td>

        </tr>
    }

    </tbody>

</table>