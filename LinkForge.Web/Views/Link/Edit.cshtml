@model LinkForge.Application.DTO.ShortLinkDto

<div class="card shadow-sm">

    <div class="card-body">

        <h4>Edit link</h4>

        <form asp-action="Edit" method="post">

            <input type="hidden" name="Id" value="@Model.Id"/>

            <div class="mb-3">

                <label class="form-label">
                    Original URL
                </label>

                <input name="OriginalUrl"
                       value="@Model.OriginalUrl"
                       class="form-control"/>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Short Code
                </label>

                <input value="@Model.ShortCode"
                       class="form-control"
                       readonly/>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Created
                </label>

                <input value="@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")"
                       class="form-control"
                       readonly/>

            </div>

            <button class="btn btn-primary">
                Save
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back
            </a>

        </form>

    </div>

</div>